# Codesteward MCP Server — local development config
#
# Copy to configs/mcp-local.yaml and fill in your values.
# Environment variables always take priority over this file.
# Point the server at it with:
#   MCP_CONFIG_FILE=configs/mcp-local.yaml codesteward-mcp
# or:
#   codesteward-mcp --config configs/mcp-local.yaml

# ── Transport ─────────────────────────────────────────────────────────────────
transport: http          # http | stdio
host: "127.0.0.1"        # bind only on loopback for local dev
port: 3000

# ── Neo4j (optional) ─────────────────────────────────────────────────────────
# Leave neo4j_password blank to run in stub mode (parse-only, no persistence).
NEO4J_URI: "bolt://localhost:7687"
NEO4J_USER: "neo4j"
NEO4J_PASSWORD: ""        # fill in to enable Neo4j persistence

# ── Default tenant / repo ─────────────────────────────────────────────────────
# Used when tools are called without explicit tenant_id / repo_id arguments.
default_tenant_id: "local"
default_repo_id: "my-repo"   # set to the name of the repo you're analysing

# ── Workspace ─────────────────────────────────────────────────────────────────
workspace_base: "workspace"  # relative to CWD, or use an absolute path

# ── Logging ───────────────────────────────────────────────────────────────────
log_level: "INFO"            # DEBUG | INFO | WARNING | ERROR
